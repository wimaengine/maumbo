{
  "extends": "astro/tsconfigs/strict",
  "include": [
    "../website/**/*",
    "../astro.config.mjs",
    ".astro/types.d.ts"
  ],
  "compilerOptions": {
    "baseUrl": "..",
    "paths": {
      "@configs": [
        "./website/config/index.ts"
      ],
      "@configs/*": [
        "./website/config/*"
      ],
      "@layouts/*": [
        "./website/layouts/*"
      ],
      "@components/*": [
        "./website/components/*"
      ]
    },
    "types": [
      "astro/client",
      "node"
    ],
    "composite": true,
    "noEmit": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": ".."
  }
}
