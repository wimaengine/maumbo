---
import { getCollection, render } from "astro:content";
import { sidebarTabs } from "@configs";
import DocLayout from "@layouts/DocLayout.astro";

const guides = await getCollection("guide");
const entry = guides.find((guide) => {
  const raw = guide.slug ?? guide.id;
  return raw.replace(/\.md$/, "") === "index";
});

if (!entry) {
  throw new Error('Missing guide index entry');
}

const { Content } = await render(entry);
---

<DocLayout title={`${entry.data.title} | WebGLLIS`} tabs={sidebarTabs}>
  <Content />
</DocLayout>
