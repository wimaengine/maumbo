---
import { getCollection } from "astro:content";
import DocLayout from "@layouts/DocLayout.astro";
import { sidebarTabs } from "@configs";
import { withBase } from "../../utils/url";

const entries = await getCollection("examples");
const splitCamelCase = (value: string) => value.replace(/([a-z0-9])([A-Z])/g, "$1 $2");
const formatCategory = (value: string) => splitCamelCase(value).replaceAll("/", " / ");

const examples = entries
  .map((entry) => ({
    slug: entry.id,
    title: splitCamelCase(entry.data.title),
    directory: entry.id.split("/").slice(0, -1).join("/"),
    description: entry.data.description
  }))
  .sort((a, b) => {
    const dirCompare = a.directory.localeCompare(b.directory);
    if (dirCompare !== 0) return dirCompare;
    return a.title.localeCompare(b.title);
  }, {});

const groupedExamples = examples.reduce<Record<string, typeof examples>>((acc, example) => {
  const key = example.directory || "uncategorized";
  if (!acc[key]) acc[key] = [];
  acc[key].push(example);
  return acc;
}, {});

const categories = Object.entries(groupedExamples);
---

<DocLayout title="Examples | WebGLLIS" tabs={sidebarTabs}>
  <h1>Examples</h1>
  <p>Browse runnable examples from the repository.</p>

  {categories.map(([category, categoryExamples]) => (
    <section class="category-section">
      <h2>{formatCategory(category)}</h2>
      <div class="examples-grid">
        {categoryExamples.map((example) => (
          <a class="example-card" href={withBase(`/examples/${example.slug}`)}>
            <img src={withBase("/images/uv.jpg")} alt="" loading="lazy" />
            <span>{example.title}</span>
          </a>
        ))}
      </div>
    </section>
  ))}
</DocLayout>

<style>
  .category-section + .category-section {
    margin-top: 2rem;
  }

  .category-section h2 {
    margin-bottom: 0.75rem;
  }

  .examples-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .example-card {
    position: relative;
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border: 1px solid #2f333b;
    border-radius: 10px;
    background: #ffffff;
    text-decoration: none;
  }

  .example-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .example-card span {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 0.55rem 0.75rem;
    text-align: center;
    color: #ffffff;
    font-weight: 700;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.15));
  }
</style>
