---
import { getCollection, type CollectionEntry } from "astro:content";
import { getExampleImportMap } from "../../../utils/example";

type Props = {
  entry: CollectionEntry<"examples">;
};

export async function getStaticPaths() {
  const entries = await getCollection("examples");

  return entries.map((entry: CollectionEntry<"examples">) => ({
    params: { slug: entry.id },
    props: { entry }
  }));
}

const { entry } = Astro.props as Props;
const mainUrl = "./main.js";
const importMap = getExampleImportMap(import.meta.env.PROD);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{entry.data.title}</title>
    <style is:global>
      html,
      body {
        margin: 0;
        width: 100%;
        height: 100%;
        background: #ffffff;
        overflow: hidden;
      }

      canvas {
        background-color: black;
        touch-action: none;
      }

      .performance-monitor {
        position: fixed;
        top: 0%;
        right: 0%;
        cursor: pointer;
        opacity: 0.9;
        z-index: 10000;
      }
    </style>
    <script type="importmap" set:html={importMap}></script>
  </head>
  <body>
    <script type="module" src={mainUrl}></script>
  </body>
</html>
