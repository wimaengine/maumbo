---
import { getCollection, type CollectionEntry } from "astro:content";
import { Code } from "astro:components";
import DocLayout from "@layouts/DocLayout.astro";
import { sidebarTabs } from "@configs/navigation";
import { withBase } from "../../../utils/url";

type Props = {
  entry: CollectionEntry<"examples">;
};

export async function getStaticPaths() {
  const entries = await getCollection("examples");

  return entries.map((entry: CollectionEntry<"examples">) => ({
    params: { slug: entry.id },
    props: { entry }
  }));
}

const { entry } = Astro.props as Props;
const title = entry.data.title;
const sampleUrl = withBase(`/examples/${entry.id}/sample`);
---

<DocLayout title={`${title} | Maumbo`} tabs={sidebarTabs}>
  <div class="example-frame">
    <a href={withBase("/examples")}>← Back to examples</a>
    <h1 style="text-align:center">{title}</h1>
    <a class="example-link" href={sampleUrl} target="_blank" rel="noreferrer">
      Open as a stand-alone example
    </a>
    <iframe
      title={`${title} preview`}
      src={sampleUrl}
      style="display:block;width:min(100%,1000px);height:560px;background:#fff;border:1px solid #d1d5db;border-radius:8px;margin:0 0 1.25rem;"
    />
  </div>
  <p>Source file: {entry.data.filePath}</p>
  <div class="source-code">
    <Code code={entry.data.source} lang="js" />
  </div>
</DocLayout>

<style>
  .example-frame {
    position: relative;
    width: min(100%, 1000px);
    margin-bottom: 1.25rem;
  }

  .example-link {
    position: absolute;
    top: 7rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    color: #22d3ee;
    text-decoration: underline;
    font-weight: 600;
    background: rgba(0, 0, 0, 0.35);
    padding: 0.2rem 0.5rem;
    border-radius: 6px;
  }

  .example-link:hover {
    color: #67e8f9;
  }

  .source-code {
    outline: 1px solid #3f4754;
    outline-offset: 0;
    border-radius: 8px;
    overflow: hidden;
  }

  .source-code pre {
    margin: 0px;
    padding: 10px;
  }
</style>
