{
  "name": "maumbo",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "npm run dev",
    "dev": "astro dev",
    "test": "node --test",
    "build": "npm run build:lib && npm run build:website",
    "build:lib": "rollup -c .config/rollup.config.js",
    "build:website": "astro build",
    "clean": "npm run clean:lib",
    "clean:lib": "rm -r dist"
  },
  "exports": {
    ".": {
      "import": "./dist/index.module.js",
      "require": "./dist/index.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "author": "Wima engine contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/wimaengine/maumbo.git"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "astro": "^6.1.3",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.0.1",
    "rollup": "^4.60.0",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "typescript": "~5.9.3"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "hisabati": "^0.1.0",
    "marangi": "^0.1.0"
  }
}
